# ===================================
# GITIGNORE - PGI AUTOMOBILE
# ===================================

# Configuration locale (en production, ne pas committer ces fichiers)
# config/database.php est commité car il contient uniquement les valeurs par défaut de développement
# En production, remplacer les valeurs directement dans ce fichier (ne pas committer les credentials)
.env
config/config.php

# Logs
logs/*.log
*.log

# Fichiers temporaires
tmp/*
!tmp/.gitkeep

# Uploads
assets/images/uploads/*
!assets/images/uploads/.gitkeep

# Cache
*.cache
cache/

# Composer
vendor/
composer.lock

# IDE
.idea/
.vscode/
*.sublime-*
.DS_Store

# OS
Thumbs.db
desktop.ini

# Backup
*.bak
*.backup
*.old

# Database dumps
*.sql.gz
*.sql.zip
backup_*.sql
